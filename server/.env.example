PORT=5000
NODE_ENV=development

# MongoDB Atlas Configuration
# Substitua com sua string de conexão do MongoDB Atlas
# Exemplo: mongodb+srv://usuario:senha@cluster.mongodb.net/escola?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://seu_usuario:sua_senha@cluster0.xxxxx.mongodb.net/escola?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=seu_secret_super_seguro_aqui_mude_em_producao_12345678
JWT_EXPIRE=30d

# Server Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Configurações da Aplicação
MAX_ALUNOS_POR_TURMA=35
ANO_LETIVO_ATUAL=2026
NUMERO_TRIMESTRES=3
